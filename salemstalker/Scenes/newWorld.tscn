[node name="Dillon" parent="Mason/IsGay" instance=ExtResource("421_81rqo")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3.5462093, 1.9490459, 37.886063)
visible = false
script = ExtResource("424_nr7af")
NPCName = "Dillon"
InitialDialogue = "Gosh darn it! Those damn rats keep eating our food! "
QuestDialogue = Array[String](["Hey! I heard you're looking for some clues about those cultists, and I might have found a lead.", "I believe it has something to do with those stinking rats, but we have no way in dealing with them. They're way too quick for us.", "They keep eating all our food and seem to have some sort of purple glow to them. Won't you help us by killing those rodents?"])
AcceptedDialogue = Array[String](["Thanks Inquisitor sir. Make sure those rodents never try eating our food again."])
IgnoredDialogue = Array[String](["Hmph. There's gotta be a way to drive them out..."])
WaitingDialogue = "I still see rats scurrying about. "
DoneDialogue = Array[String](["Hmph! Not too shabby. We'll finally be able to eat food in peace. Thank you sir.", "I believe those rats came from outside the village from some sort of campsite. That's all I know. "])
PostDoneDialogue = "We can finally eat food again. Thank you. "
QuestTitle = "Find and kill rats around Brittlebay village"
QuestGoal = "0/5"
_questComplete = true

