[node name="Samuel" parent="." instance=ExtResource("421_81rqo")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -12.565277, 1.9490459, 53.176186)
visible = false
script = ExtResource("426_xyhap")
NPCName = "Samuel"
InitialDialogue = "Somebody please! Help my son!"
QuestDialogue = Array[String](["Lord Inquisitor! My son has been ill for quite some time now. He's gotten worse, but the local Wizard has figured out a cure.", "Please, won't you gather the resources needed so I can craft the medicine?"])
AcceptedDialogue = Array[String](["Oh thank you! Once you have what's needed, please give them to me so I can make the medicine. Please be quick!"])
IgnoredDialogue = Array[String](["No. But my son..."])
WaitingDialogue = "Please deliver the resources to me soon."
DoneDialogue = Array[String](["You did it! I'll make the medicine for my boy as soon as I can. Thank you so much!"])
PostDoneDialogue = "My son will get better soon. Thank you again."
QuestTitle = "Gather monster resources and deliver it to Samuel so he can craft a medicine"
QuestGoal = "Bleeding Heart: 0/3, Dead Ooze: 0/4, Seed: 0/2"

[node name="Martha" parent="." instance=ExtResource("421_81rqo")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -14.576809, 1.9490459, 64.33432)
script = ExtResource("427_46020")
NPCName = "Martha"
InitialDialogue = "Those Cultists took my family! Something must be done! "
QuestDialogue = Array[String](["Lord Inquisitor! Those cultists took my husband and daughter and changed them into these creatures of darkness right in front of my eyes!", "Please, won't you get the vengeance that they deserve?"])
AcceptedDialogue = Array[String](["Oh thank you Lord Inquisitor! May Her Lady's grace forever be upon us. Please return to me once those monsters are brought to justice."])
IgnoredDialogue = Array[String](["Maybe someone else can help me."])
WaitingDialogue = "My family won't be brought to justice until those monsters are dead!"
DoneDialogue = Array[String](["Thank you, oh thank you so much Lord Inquisitor! My husband and daughter may now rest in peace. If you find any more of those cultists, make sure they get what they deserve."])
PostDoneDialogue = "My family can now rest in peace. Thank you."
QuestTitle = "Kill creatures that reside in the forest to avenge Martha's family"
QuestGoal = "Forest: 0/5"

