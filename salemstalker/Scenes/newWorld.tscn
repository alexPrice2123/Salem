[node name="Mary" parent="." instance=ExtResource("421_81rqo")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -7.8680115, 1.9490459, 37.633118)
script = ExtResource("422_pvlar")
NPCName = "Mary"
InitialDialogue = "Oh my sweet little babies! Please come back to me!"
QuestDialogue = Array[String](["Lord Inquisitor sir! Won't you help an old woman out? I've lost my young and dearest kitties, Taz, Bridger, and Gnocchi.", "I last saw them approach some strange individuals in purple robes outside of the village.", "Would you please find them and bring them back home?"])
AcceptedDialogue = Array[String](["Oh thank you! Please make sure they comes back safely."])
IgnoredDialogue = Array[String](["Oh dear. Maybe they'll come back on their own some day..."])
WaitingDialogue = "Have you found my babies yet?"
DoneDialogue = Array[String](["Oh thank you Lord Inquisitor! Don't ever leave me again my cuties. Mama Mary will protect you here."])
PostDoneDialogue = "Ahhh! No biting Bridger. "
QuestTitle = "Find Mary's lost cats, Taz, Bridger, and Gnocchi, somewhere in the woods near Brittlebay village"
QuestGoal = "0/3"

