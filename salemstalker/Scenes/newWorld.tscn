[node name="Richard" parent="." instance=ExtResource("421_81rqo")]
transform = Transform3D(-0.70710677, 0, 0.70710677, 0, 1, 0, -0.70710677, 0, -0.70710677, -233.28224, 2.0682552, 768.4027)
script = ExtResource("926_lmwmg")
NPCName = "Inquisitor Richard"
InitialDialogue = ""
QuestDialogue = Array[String](["Here we are rookie. Saltus Island. Took us quite a while to reach it.", "Our King shall be pleased once we've completed our mission, so let's get it done quickly now shall we?", "You've been a little quiet since we got here. You doing alright? I can debrief the mission again if you'd like."])
AcceptedDialogue = Array[String](["All right rookie. Let me recount the details for you once more.", "As Inquisitors, It's our holy duty to assist the vast regions of the Whilstrum Kingdom in dire times of need.", "Our King has tasked us to investigate the disturbances occurring in Saltus, a far off island from the Kingdom's capital.", "We've been told that there's been a series of kidnappings, deaths, and even open defiance to our God, Xoraya. ", "From the information we've been given, a new cultist group has emerged on the island. They may have something to do with what's been going on.", "Now that you're caught up with our mission, let's start our holy work.", "I heard back at the capital of your incredible fighting skills, make good use of it when you're in danger. We don't want to lose more capable people.", "I'll get more of our supplies from the ship. Why don't you go investigate the village down the path? They may know something we don't."])
IgnoredDialogue = Array[String](["Well good thing you remember, we've got a lot to do.", "I'll get more of our supplies from the ship. Why don't you go investigate the village down the path? They may know something we don't."])
WaitingDialogue = "Check up on that village down the road. I'll get our supplies."

