[node name="Finn" parent="." instance=ExtResource("421_81rqo")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -2.6124573, 1.9490459, 27.18628)
visible = false
script = ExtResource("428_of432")
NPCName = "Finn"
InitialDialogue = "Master Inquisitor, I've got some valuable information you may want to hear."
QuestDialogue = Array[String](["After we had to move from our past village, we left a lot of valuable things behind.", "I heard of a useful tool somewhere in Willow-Mire. You may want to check it out."])
AcceptedDialogue = Array[String](["Be careful when looking around the town. It's changed since the last time we were there. Be on your guard."])
IgnoredDialogue = Array[String](["You may want to reconsider. It could help you further down the road."])
WaitingDialogue = "I still wonder what that tool could be."
PostDoneDialogue = "So the tool was some caltrops? Sounds useful."
QuestTitle = "Find the hidden weapon somewhere in the swamp island village"
