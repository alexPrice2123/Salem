[node name="Lukas" parent="." instance=ExtResource("421_81rqo")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, -1.9220867, 1.9490459, 51.938004)
script = ExtResource("425_ym0xd")
NPCName = "Lukas"
InitialDialogue = "Please, is there who'd hear me out? I've made such an important discovery!"
QuestDialogue = Array[String](["Oh, Master Inquisitor. It's good to see the royal capital lending out a hand to Saltus.", "I've been doing some digging of my own into what's been going on around here and I've found something you may want to hear.", "There's been strange wooden shrines appearing around our village by some hooded individuals.", "I believe those damn Cultists set them up, and it seems to be enhancing their powers by summoning more creatures of Kyron, the God of Darkness.", "You seem like a capable fighter. Please, would you do us a favor and destroy those Shrines?"])
AcceptedDialogue = Array[String](["Oh we are truly grateful Master Inquisitor. The King and Her holiness shall forever be in our debt.", "I marked the locations of those shrines on your map. Come back to me once those shrines have been vanquished. "])
IgnoredDialogue = Array[String](["I understand. You must have a lot happening currently."])
WaitingDialogue = "Look on your map for those shrines. "
DoneDialogue = Array[String](["You did it! Our village is now safe once again. I'll look into those shrines more in the meantime.", "You may get some more information from the town Wizard if you haven't already spoken to him."])
PostDoneDialogue = "I heard of shrine sightings in the next village over..."
QuestTitle = "Destroy the Cultist's shrines found around Brittlebay village"
QuestGoal = "0/3"

