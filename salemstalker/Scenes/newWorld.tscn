[node name="Matthew" parent="Mason/IsGay" instance=ExtResource("421_81rqo")]
transform = Transform3D(0, 0, 0.99999994, 0, 1, 0, -0.99999994, 0, 0, -32.437317, 2.0682554, 60.267693)
script = ExtResource("429_wkm1a")
NPCName = "Matthew"
InitialDialogue = ""
QuestDialogue = Array[String](["Young man, are you alright? You don't look too well...", "From the looks of it, you seem to be an Inquisitor... from the Kingdom's capital!?", "Please excuse my rudeness Master Inquisitor, I only meant to see if you weren't in any harm. You seem to be alright from the looks of it.", "It's such a relief that the King sent over Inquisitors. The island of Saltus is in dire need of your help.", "Please, assist some of my village's townsfolk in their needs, then you'll understand more of what's going on here.", "Oh, and one more thing, Master Inquisitor. Welcome to Brittlebay village. My name is Matthew, and I am the chief of this village. May Her holy light shine upon us all. "])
AcceptedDialogue = []
IgnoredDialogue = []
WaitingDialogue = "Please help out the townsfolk. We need your help."

