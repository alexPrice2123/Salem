[node name="Elizabeth" parent="." instance=ExtResource("421_81rqo")]
transform = Transform3D(1, 0, 0, 0, 1, 0, 0, 0, 1, 3.3819237, 1.9490459, 35.37815)
script = ExtResource("423_e2eg3")
NPCName = "Elizabeth"
InitialDialogue = "Where have the lumberjacks gone? It's too cold..."
QuestDialogue = Array[String](["My husband, along with other Lumberjacks from our town have gone missing over the past few days and we've been out of firewood.", "Would you please gather some firewood so we can stay warm? You may run into those lumberers somewhere in the woods too. "])
AcceptedDialogue = Array[String](["Thank you Lord Inquisitor. Please come back to me once you've gotten enough.", "Let me know if you gather any information of their whereabouts. "])
IgnoredDialogue = Array[String](["Oh, that's alright. Maybe those lumberjacks will come back soon."])
WaitingDialogue = "Still waiting on that firewood once you've gathered enough."
DoneDialogue = Array[String](["Yes! This should be enough to keep us warm for a while. Thank you.", "It's a shame you couldn't find those lumberjacks. I do hope they come back safely. "])
PostDoneDialogue = "Now we'll stay warm through the night."
QuestTitle = "Gather firewood around Brittlebay's woods for Elizabeth"
QuestGoal = "0/15"

